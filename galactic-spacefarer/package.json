{
  "name": "galactic-spacefarer",
  "version": "1.0.0",
  "description": "Welcome to your new CAP project.",
  "main": "index.js",
  "scripts": {
    "start": "cds watch",
    "watch-spacefarers": "cds watch --open spacefarers/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@cap-js/sqlite": "^2.2.0",
    "@sap/cds": "^9.8.2",
    "dotenv": "^17.3.1",
    "nodemailer": "^8.0.2"
  },
  "cds": {
    "requires": {
      "auth": {
        "kind": "basic",
        "users": {
          "planetx": {
            "password": "planetx",
            "roles": [
              "authenticated-user"
            ],
            "attr": {
              "planet": "Planet X"
            }
          },
          "planety": {
            "password": "planety",
            "roles": [
              "authenticated-user"
            ],
            "attr": {
              "planet": "Planet Y"
            }
          },
          "admin": {
            "password": "admin",
            "roles": [
              "authenticated-user",
              "admin"
            ]
          }
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "devDependencies": {
    "cds-plugin-ui5": "^0.13.0"
  },
  "sapux": [
    "app/spacefarers"
  ]
}
